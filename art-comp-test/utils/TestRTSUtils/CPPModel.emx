            <effect xmi:type="uml:OpaqueBehavior" xmi:id="_taPz4BRnEeuMep6o3b6wQQ" name="Effect">
              <language><![CDATA[C++]]></language>
              <body><![CDATA[
unsigned int testLimit = 2; // Default testcase timeout
TestUtils::getTestOptions(testLimit);

timer = timing.informIn(RTTimespec(testLimit, 0));
if (!timer.isValid()) {
	TestUtils::fail("Failed to set timer");
}
]]></body>
            </effect>
