let tc = TCF.define(TCF.CPP_TRANSFORM);
tc.sources = [
    'platform:/resource/TestRTSUtils/CPPModel.emx#_57HTcBRnEeuMep6o3b6wQQ',
];
tc._TestUtils = java.nio.file.Paths.get(TCF.resolveURI(tc.getId())).resolve('../../TestUtils').normalize().toString().replaceAll('\\\\', '/');
