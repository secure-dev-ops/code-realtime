capsule BaseC {
    behavior port timer : Timing;
    statemachine {
        choice c;
        state First, Third;
        a: First -> c on timer.timeout;
        x: c -> Third
        `
            FAIL("Executed transition with excluded state");
        `;
        i: initial -> First
        `
            timer.informIn(RTTimespec(0, 500));
        `;
    };
};

capsule Top : BaseC {
    statemachine { // Should NOT get ART_0007 here. Transition "x" is implicitly excluded since "Third" is excluded.
        state Fourth;
        y: c -> Fourth
        `
            PASS();
        `;
        state exclude Third;
    };
};
