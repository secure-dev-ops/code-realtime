
protocol TheProtocol {
    [[rt::header_preface]]
    `
        #include "RTType_Types.h"
    `
    out e1(`MyString`);
    out e2(`MyVector`);
};

capsule Cap {
    service behavior port pIn~ : TheProtocol;
    statemachine {
        initial -> State1;
        state State1 {
            str_received: on pIn.e1
            `
                std::string encoding = TestUtils::getASCIIEncodedString(msg->getData(), msg->getType());
                ASSERT(encoding == "MyString\"Hello World!\"", encoding.c_str());
            `;

            vec_received: on pIn.e2
            `
                std::string encoding = TestUtils::getASCIIEncodedString(msg->getData(), msg->getType());
                ASSERT(encoding == "MyVector[1,2,3,4]", encoding.c_str());

                PASS();
            `;
        };
    };
};

capsule Top {
    part cap : Cap;
    behavior port pOut : TheProtocol;
    connect pOut with cap.pIn;

    statemachine {
        state State1 {
            entry
            `
                MyString str("Hello World!");
                MyVector vec{1,2,3,4};
                pOut.e1(str).send();
                pOut.e2(vec).send();
            `;
        };
        initial -> State1;
    };
};
