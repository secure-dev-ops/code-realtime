
protocol TheProtocol {
    [[rt::header_preface]]
    `
        #include "RTType_Data.h"
    `
    out e1(`Container`);    
};

capsule Cap {    
    [[rt::impl_preface]]
    `
        #include "RTType_Data.h"
    `
    service behavior port pIn~ : TheProtocol;
    statemachine {
        state State1, State2;
        initial -> State1;
        State1 -> State2 on pIn.e1
        `
            std::cout << "Got the data! " << std::endl;
            ASSERT(rtdata->d.value == 0, "Container::d had wrong contents");
            ASSERT(rtdata->pd->value == 42, "Container::pd had wrong contents");
            const RTObject_class* mt = msg->getType();
            ASSERT(mt == &RTType_Container, "msg type should point to Container type descriptor");
            std::string encoding = TestUtils::getASCIIEncodedString(msg->getData(), mt);
            std::cout << "Encoding: " << encoding << std::endl;
            ASSERT(encoding == "Container{d{value 0},pd{{value 42}}}", encoding.c_str());
            PASS();
        `;
    };
};

capsule Top { 
    [[rt::impl_preface]]
    `
        #include "Data.h"
    `
    part cap : Cap;
    behavior port pOut : TheProtocol;    
    connect pOut with cap.pIn;

    statemachine {
        state State1 {
            entry
            `
                Container c;
                c.pd = new Data(42);

                pOut.e1(c).send();
            `;
        };  
        initial -> State1;
    };
};
